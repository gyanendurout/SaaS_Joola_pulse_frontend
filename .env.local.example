# Supabase — required for the dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# IMPORTANT: anon/public key only — never the service-role key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Optional — used only by scripts/scrape_joola_ig.py, never by the Next.js app
SUPABASE_SERVICE_ROLE_KEY=
APIFY_API_TOKEN=
OPENAI_API_KEY=
